---
import { getCollection } from "astro:content";
import ProjectCard from "../components/ProjectCard.astro";

const projects = await getCollection('projects')

---

<section class="py-15">

    <h2 class="max-w-7xl mx-auto px-6 text-4xl text-center uppercase tracking-tighter font-bold md:text-8xl md:text-left">
        Proyectos
        <br>
        <span class="text-transparent [-webkit-text-stroke:0.5px_gray]">Archivos</span>
    </h2>

    <div class="border-t border-white/10 mt-15 px-6">
        
        <ul class="max-w-7xl mx-auto grid grid-cols-1 border-white/10 divide-white/10 md:grid-cols-[0.8fr_0.8fr_0.8fr] md:grid-rows-[0.5fr_0.5fr_0.5fr]">
            {projects.map((project) => (
                <ProjectCard project={project} />
            ))}
        </ul>

    </div>
</section>