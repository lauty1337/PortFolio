---
import { Image } from "astro:assets";
import LinkedIn from "../assets/svg/LinkedIn.svg";
import Download from "../assets/svg/Download.svg";
import profile from "../assets/images/fotomia.webp";
---

<section data-hero-section class="sticky top-0 z-10 bg-black overflow-hidden min-h-dvh border-b border-white/10">

    <div class="relative items-center flex flex-col mx-auto px-6 pt-28 md:pt-36 pb-16">

        <a data-hero-tagline href="/contact" class="group flex items-center gap-x-2 text-xs mb-8 px-3 py-1.5 border border-white/15 hover:border-white/30 hover:shadow-lg hover:shadow-white/5 transition-colors duration-200">
            <span class="relative flex size-2">
                <span class="absolute inline-flex size-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex size-2 rounded-full bg-emerald-500"></span>
            </span>
            Disponible para trabajar
        </a>

        <p data-hero-name class="text-xs md:text-sm font-secondary text-gray-400 tracking-wide">
            Hey, soy Lautaro Sanchez Visser
        </p>

        <h1 data-hero-title class="relative mt-6 text-[45px] font-bold font-primary uppercase tracking-tighter text-center md:text-8xl lg:text-[130px] xl:text-[180px]">
            Desarrollador
            <br>
            <span class="text-transparent [-webkit-text-stroke:2px_gray]">Front-End</span>
        </h1>

        <div data-hero-cta class="flex flex-col mt-10 justify-center z-50 items-center gap-4 md:flex-row md:mt-60 lg:mt-40 ">
            <a href="/curriculum.pdf" 
            class="px-6 py-2.5 flex  items-center gap-x-2 bg-white text-black border-black/10 border text-xs font-secondary hover:bg-gray-100 hover:border-black/20 duration-200">
                <Download class="size-4" />
                Descargar Curriculum
            </a>
            <a href="https://linkedin.com/in/lautaro-sanchez-visser" class="flex items-center gap-x-2 px-6 py-2.5 border border-white/10 bg-[#101010] text-xs font-secondary hover:border-white/20 hover:bg-black duration-200  ">
                <LinkedIn class="size-4" />
                LinkedIn
            </a>
        </div>
        
        <div data-hero-image class="absolute inset-x-0 left-6 top-120 flex items-center justify-center md:top-55">
            <Image 
            src={profile} 
            alt="Foto de Lautaro Sanchez Visser"
            width={350}
            height={350}
            priority
            class="w-auto h-[350px] object-cover grayscale hover:grayscale-0 transition-all duration-700 mask-b-from-40% mask-b-to-90% md:h-[1000px] md:mask-b-to-65% " 
            />
        </div>
    </div>
</section>

<script src="../scripts/animations/hero.js"></script>