---
import type { CollectionEntry } from "astro:content";
import ArrowRightIcon from "./Icons/ArrowRightIcon.astro";

interface Props {
    project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { data, slug } = project;


---

<li>
    <article class="border border-white/10 p-6 h-full">

        <div class="flex justify-between items-center">

            <span class="text-xs opacity-30">
                {data.subtitle}
            </span>

            <a href={`/projects/${slug}`} class="group flex text-xs items-center gap-x-2 py-1 px-3 border border-white/10 rounded-sm hover:border-white/20 transition-all duration-200">
                Saber mas
                <ArrowRightIcon class="size-4 group-hover:translate-x-1 transition-all duration-200"/>
            </a>

        </div>
    </article>
</li>