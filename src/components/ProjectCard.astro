---
import type { CollectionEntry } from "astro:content";
import ArrowRightIcon from "./Icons/ArrowRightIcon.astro";

interface Props {
    project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { data, slug } = project;

const sizesClasses = {
    "large": "lg:col-span-2 ",
    "tall": "md:col-span-2 lg:row-span-1 lg:col-span-1",
    "medium": "lg:col-span-1",
}


---

<li class={sizesClasses[data.size as keyof typeof sizesClasses]}>
    <article class="group border relative flex flex-col border-white/10 p-6 h-full">

        <div class="flex justify-between items-center">

            <span class="text-xs opacity-10 ">
                {data.subtitle}
            </span>

            <a href={`/projects/${slug}`} class="group flex text-xs items-center gap-x-2 py-1 px-3 border border-white/10 rounded-xs hover:border-white/20 transition-all duration-200">
                Saber mas
                <ArrowRightIcon class="size-4 group-hover:translate-x-1 transition-all duration-200"/>
            </a>

        </div>

        <figure class="relative overflow-hidden group-hover:scale-105 transition-all duration-700 mt-4 flex-1 flex justify-center items-center min-h-[70px]">
            <img
            transition:name={`${slug}-image`}
            src={`/src/assets/images/projects/${data.img}`} 
            alt={data.title} 
            loading="lazy" 
            decoding="async" 
            class="w-[600px] hover:scale-135 transition-all duration-300 h-full object-cover" 
            />
            <div class="absolute inset-0 bg-linear-to-b from-transparent from-10% to-black opacity-100 group-hover:opacity-30 transition-opacity duration-700"></div>
        </figure>

        <h3 class="text-2xl mt-4 uppercase font-bold md:text-6xl" transition:name={`${slug}-title`}>
            {data.title}
        </h3>

        <p class="text-sm mt-4 text-paragraph leading-relaxed ">
            {data.description}
        </p>

        <ul class="flex flex-wrap gap-2 mt-auto pt-4">
            {data.stack.map((stack) => (
                <li class="text-xs px-2 py-1 bg-white/10 rounded-xs text-white/50 hover:text-white transition-colors duration-200">
                    {stack}
                </li>
            ))}
        </ul>
    </article>
</li>